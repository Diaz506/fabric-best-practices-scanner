	/// Whether the resource is orphaned/unused (Yes | No).
	column 'Orphaned'
		dataType: string
		lineageTag: 6c4b2d33-1e55-4f88-ab21-9a3c7d2e030e
		summarizeBy: none
		sourceColumn: is_orphan

		annotation SummarizationSetBy = Automatic

	/// Comma-separated reasons the resource was flagged as orphaned/unused.
	column 'Why flagged'
		dataType: string
		lineageTag: 6c4b2d33-1e55-4f88-ab21-9a3c7d2e030f
		summarizeBy: none
		sourceColumn: orphan_reasons

		annotation SummarizationSetBy = Automatic

	/// --- Latest-snapshot inventory measures (current state) --------------------

	/// run_id of the most recent inventory snapshot; anchors the current-state counts.
	measure 'Latest Inventory Run ID' = ```
			VAR MaxTs = MAX ( governance_inventory[Timestamp] )
			RETURN
			    CALCULATE (
			        SELECTEDVALUE ( governance_inventory[Run ID] ),
			        FILTER ( ALL ( governance_inventory ), governance_inventory[Timestamp] = MaxTs )
			    )
			```
		lineageTag: 6c4b2d33-1e55-4f88-ab21-9a3c7d2e0400

	measure 'Resources (Latest Run)' = ```
			VAR lr = [Latest Inventory Run ID]
			RETURN
			    CALCULATE ( COUNTROWS ( governance_inventory ), governance_inventory[Run ID] = lr )
			```
		formatString: 0
		lineageTag: 6c4b2d33-1e55-4f88-ab21-9a3c7d2e0401

	measure 'Orphaned Resources (Latest Run)' = CALCULATE ( [Resources (Latest Run)], KEEPFILTERS ( governance_inventory[Orphaned] = "Yes" ) )
		formatString: 0
		lineageTag: 6c4b2d33-1e55-4f88-ab21-9a3c7d2e0402

	measure 'Workspaces (Latest Run)' = CALCULATE ( [Resources (Latest Run)], KEEPFILTERS ( governance_inventory[Resource type] = "Workspace" ) )
		formatString: 0
		lineageTag: 6c4b2d33-1e55-4f88-ab21-9a3c7d2e0403

	measure 'Capacities (Latest Run)' = CALCULATE ( [Resources (Latest Run)], KEEPFILTERS ( governance_inventory[Resource type] = "Capacity" ) )
		formatString: 0
		lineageTag: 6c4b2d33-1e55-4f88-ab21-9a3c7d2e0404

	measure 'Domains (Latest Run)' = CALCULATE ( [Resources (Latest Run)], KEEPFILTERS ( governance_inventory[Resource type] = "Domain" ) )
		formatString: 0
		lineageTag: 6c4b2d33-1e55-4f88-ab21-9a3c7d2e0405

	/// Capacities in the latest snapshot with no workspaces assigned (candidates to pause or remove).
	measure 'Capacities Without Workspaces (Latest Run)' = ```
			VAR lr = [Latest Inventory Run ID]
			RETURN
			    CALCULATE (
			        COUNTROWS ( governance_inventory ),
			        governance_inventory[Run ID] = lr,
			        governance_inventory[Resource type] = "Capacity",
			        CONTAINSSTRING ( governance_inventory[Why flagged], "no-workspaces-assigned" )
			    )
			```
		formatString: 0
		lineageTag: 6c4b2d33-1e55-4f88-ab21-9a3c7d2e0406

	partition governance_inventory = entity
		mode: directLake
		source
			entityName: governance_inventory
			schemaName: dbo
			expressionSource: DatabaseQuery

	annotation PBI_ResultType = Table
