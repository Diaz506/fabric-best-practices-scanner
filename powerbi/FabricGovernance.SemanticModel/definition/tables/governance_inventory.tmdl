table governance_inventory
	lineageTag: 6c4b2d33-1e55-4f88-ab21-9a3c7d2e0300

	/// The scan run identifier. One value per scan; new snapshots are appended so inventory can be trended.
	column 'Run ID'
		dataType: string
		lineageTag: 6c4b2d33-1e55-4f88-ab21-9a3c7d2e0301
		summarizeBy: none
		sourceColumn: run_id

		annotation SummarizationSetBy = Automatic

	/// ISO-8601 UTC timestamp of the inventory snapshot. Stored as text; sorts chronologically.
	column 'Timestamp'
		dataType: string
		lineageTag: 6c4b2d33-1e55-4f88-ab21-9a3c7d2e0302
		summarizeBy: none
		sourceColumn: timestamp

